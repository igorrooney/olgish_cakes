# Production Environment Variables Template for Olgish Cakes
# Copy this file to .env.production and fill in your actual values
# This file should NOT be committed to version control

# Sanity CMS Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token

# Data Fetching Configuration
# Set to 'false' for cached data with webhook revalidation, 'true' to bypass cache
NEXT_PUBLIC_USE_REAL_TIME_DATA=false
# Automatic fallback refresh for future-dated blog articles.
# Lower values publish sooner after the scheduled time, but increase Sanity reads.
ARTICLE_PUBLISH_REVALIDATE_SECONDS=300

# Analytics and Tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id
NEXT_PUBLIC_GTM_ID=your_gtm_container_id
NEXT_PUBLIC_GTAG_ID=your_gtag_id

# Contact Form Configuration
CONTACT_EMAIL=hello@olgishcakes.co.uk
CONTACT_EMAIL_TO=hello@olgishcakes.co.uk
RESEND_API_KEY=your_resend_api_key
NEXT_PUBLIC_EMAIL_FROM=hello@olgishcakes.co.uk

# Business Contact Information
# Phone number is now stored in lib/constants.ts

# Security
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=https://olgishcakes.co.uk

# Admin Authentication
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_admin_password
JWT_SECRET=your_super_secret_jwt_key_for_production_64_chars_minimum

# Email Configuration
CONTACT_EMAIL_TO=hello@olgishcakes.co.uk
CONTACT_EMAIL_BCC=backup@olgishcakes.co.uk
ORDER_EMAIL_BCC=orders@olgishcakes.co.uk
ADMIN_BCC_EMAIL=your_admin_email_for_bcc@example.com

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ENQUIRY_BUCKET=custom-cake-enquiries

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_USER_ID=your_instagram_user_id
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://127.0.0.1:4318/instagram/callback
INSTAGRAM_EMBED_URL=
INSTAGRAM_OAUTH_SCOPES=instagram_business_basic
INSTAGRAM_OAUTH_TIMEOUT_MS=15000
INSTAGRAM_GRAPH_API_VERSION=v19.0
INSTAGRAM_GRAPH_API_BASE_URL=
INSTAGRAM_POST_LIMIT=3
INSTAGRAM_REVALIDATE_SECONDS=1800
INSTAGRAM_TOKEN_EXPIRES_AT=
INSTAGRAM_TOKEN_ALERT_WINDOW_DAYS=10
INSTAGRAM_TOKEN_ALERT_TO=

# API Security Tokens
REVALIDATE_SECRET=your_random_revalidate_secret_token_here
ADMIN_SECRET_TOKEN=your_random_admin_secret_token_here
# Set this in Vercel so scheduled article revalidation can authenticate cron requests.
# Manual revalidation still uses REVALIDATE_SECRET.
CRON_SECRET=your_vercel_cron_secret_here_optional

# CSRF Protection
# Required in any environment that serves form submissions
# Generate with: openssl rand -hex 32
CSRF_SECRET=replace_with_openssl_rand_hex_32_output

# Performance and Caching
NEXT_PUBLIC_CACHE_MAX_AGE=31536000
NEXT_PUBLIC_IMAGE_OPTIMIZATION_QUALITY=85

# Feature Flags
# Set to 'false' to hide Gift Hampers from navigation and footer
NEXT_PUBLIC_FEATURE_GIFT_HAMPERS_ENABLED=false

# External Services
NEXT_PUBLIC_TRUSTPILOT_API_KEY=your_trustpilot_api_key
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_UNIT_ID=your_trustpilot_business_unit_id

# Sanity Studio URL (for preview mode)
NEXT_PUBLIC_SANITY_STUDIO_URL=https://olgishcakes.co.uk/studio

# Instructions:
# 1. Copy this file to .env.production
# 2. Replace all placeholder values with your actual production credentials
# 3. Ensure .env.production is in your .gitignore file
# 4. Deploy with your hosting provider's environment variable configuration 

# Email transport and internal test console
EMAIL_TRANSPORT_MODE=live
EMAIL_REAL_SEND_ENABLED=false
EMAIL_TEST_RECIPIENT_ALLOWLIST=
EMAIL_TEST_SUBJECT_PREFIX=[TEST]
EMAIL_REAL_SEND_RATE_LIMIT_PER_HOUR=5


